---
---

<div id="daw-root">
  
  <header id="daw-toolbar">
    <div class="tb-brand">
      <svg class="tb-logo-icon" viewBox="0 0 32 32" fill="none">
        <circle
          cx="16"
          cy="16"
          r="14"
          stroke="#ffffff"
          stroke-width="1.5"
          opacity="0.6"></circle>
        <path
          d="M10 16c0-3.3 2.7-6 6-6s6 2.7 6 6-2.7 6-6 6"
          stroke="#ffffff"
          stroke-width="1.5"
          stroke-linecap="round"></path>
        <circle cx="16" cy="16" r="2.5" fill="#ffffff"></circle>
      </svg>
      <span class="tb-brand-name"
        >STRUDEL<span class="tb-brand-sub">APP</span>
      </span>
    </div>

    <div class="tb-transport">
      <button
        id="btn-init"
        class="tb-btn tb-btn--init"
        title="Pre-load Audio Engine"
      >
        <svg viewBox="0 0 20 20" fill="currentColor"
          ><path d="M10 2a8 8 0 100 16 8 8 0 000-16zm2 11H8V7h4v6z"></path>
        </svg>
        INIT
      </button>

      <button
        id="btn-play"
        class="tb-btn tb-btn--play"
        title="Play (Ctrl+Enter)"
        disabled
      >
        <svg viewBox="0 0 20 20" fill="currentColor"
          ><polygon points="4,2 16,10 4,18"></polygon>
        </svg>
        <span id="btn-play-label">PLAY</span>
      </button>

      <button id="btn-stop" class="tb-btn tb-btn--stop" title="Stop" disabled>
        <svg viewBox="0 0 20 20" fill="currentColor"
          ><rect x="3" y="3" width="14" height="14" rx="1.5"></rect>
        </svg>
        STOP
      </button>

      <div class="tb-sep"></div>

      <div class="tb-bpm-group">
        <label class="tb-label">BPM</label>
        <button class="tb-nudge" id="bpm-down">▾</button>
        <input
          id="bpm-display"
          class="tb-bpm-val"
          type="number"
          min="20"
          max="300"
          value="120"
          title="BPM — click to edit"
        />
        <button class="tb-nudge" id="bpm-up">▴</button>
      </div>

      <div class="tb-sep"></div>

      <div class="tb-loop-group">
        <label class="tb-label">LOOP</label>
        <select id="loop-mode" class="tb-select" title="Playback behavior">
          <option value="infinite">Infinite</option>
          <option value="once">Once</option>
        </select>
      </div>

      <div class="tb-sep"></div>

      <div class="tb-time-group">
        <span class="tb-label">TIME</span>
        <span id="tb-time" class="tb-time-val">0:00.000</span>
        <span class="tb-time-sep">|</span>
        <span class="tb-label">SR</span>
        <span id="info-samplerate" class="tb-time-val" style="min-width: unset; font-size: 11px;">–</span>
      </div>
    </div>

    <div class="tb-rightmost">
      <input
        type="file"
        id="file-import"
        accept=".strudel,.txt"
        style="display: none;"
      />
      <div class="tb-action-group">
        <button
          id="btn-import-code"
          class="tb-btn tb-btn--action"
          title="Import Code">↑ LOAD</button>
        <button
          id="btn-dl-code"
          class="tb-btn tb-btn--action"
          title="Download Code">↓ SAVE</button>
        <button
          id="btn-rec-video"
          class="tb-btn tb-btn--action"
          title="Record Video">● REC</button>
      </div>
      <div class="tb-sep"></div>
      <div class="tb-status">
        <span id="status-dot" class="st-dot st-dot--idle"></span>
        <span id="status-text" class="st-text">OFFLINE</span>
      </div>
      <a href="/info" class="tb-info-btn">INFO</a>
      <div class="tb-settings-wrap">
        <button id="btn-settings" class="tb-info-btn" title="Settings">⚙</button>
        <div id="settings-popup" class="settings-popup">
          <div class="settings-popup-title">SETTINGS</div>
          <div class="settings-popup-row">
            <span class="settings-popup-lbl">FONT SIZE</span>
            <div class="setting-controls">
              <button id="sp-font-down" class="setting-btn">−</button>
              <span id="sp-font-val" class="setting-val">13</span>
              <button id="sp-font-up" class="setting-btn">+</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div id="daw-main">
    
    <aside id="panel-code">
      <div class="panel-titlebar">
        <span class="panel-title">
          <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"
            ><path
              d="M5.5 2l-4 6 4 6M10.5 2l4 6-4 6"
              stroke="currentColor"
              stroke-width="1.5"
              fill="none"></path>
          </svg>
          PATTERN EDITOR
        </span>
        <div class="panel-actions">
          <button
            id="btn-undo"
            class="panel-action-btn panel-icon-btn"
            title="Undo (Ctrl+Z)">↺</button>
          <button
            id="btn-redo"
            class="panel-action-btn panel-icon-btn"
            title="Redo (Ctrl+Shift+Z)">↻</button>
          <div class="panel-actions-sep"></div>
          <button
            id="btn-clear"
            class="panel-action-btn btn-danger"
            title="Clear Code">CLEAR</button
          >
        </div>
      </div>

      <div class="editor-area">
        <div id="line-numbers" class="line-numbers" aria-hidden="true">1</div>
        <textarea
          id="sp-code"
          class="sp-code"
          spellcheck="false"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          aria-label="Strudel pattern code"></textarea>
      </div>

      <pre id="sp-error" class="error-console" hidden></pre>
    </aside>

    <div id="panel-right">
      <div class="r-panel" id="scope-panel">
        <div class="panel-titlebar">
          <span class="panel-title">
            <svg
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              width="12"
              height="12"
              ><polyline points="0,8 3,5 6,11 9,3 12,8 15,6"></polyline>
            </svg>
            OSCILLOSCOPE
          </span>
          <span id="scope-db" class="scope-db">— dB</span>
        </div>
        <canvas id="sp-visualizer" class="scope-canvas" aria-hidden="true"
        ></canvas>
      </div>

      <div class="r-panel" id="spectrum-panel">
        <div class="panel-titlebar">
          <span class="panel-title">
            <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"
              ><rect x="0" y="8" width="3" height="8"></rect><rect
                x="4"
                y="4"
                width="3"
                height="12"></rect><rect x="8" y="2" width="3" height="14"
              ></rect><rect x="12" y="6" width="3" height="10"></rect>
            </svg>
            SPECTRUM
          </span>
        </div>
        <canvas id="sp-spectrum" class="scope-canvas" aria-hidden="true"
        ></canvas>
      </div>


      <div id="bottom-panels">
        <div class="r-panel" id="settings-panel">
          <div class="panel-titlebar">
            <span class="panel-title">BEAT & MUSIC</span>
            <button id="btn-tap" class="tap-btn" title="Tap to set BPM">TAP</button>
          </div>
          <div class="merged-settings-content">
            <div class="beat-grid">
              <div class="beat-dot" id="beat-0"></div>
              <div class="beat-dot" id="beat-1"></div>
              <div class="beat-dot" id="beat-2"></div>
              <div class="beat-dot" id="beat-3"></div>
            </div>
            <div class="merged-divider"></div>
            <div class="setting-row">
              <span class="setting-lbl">VOLUME</span>
              <div class="setting-controls">
                <input type="range" id="master-vol" min="0" max="1" step="0.01" value="0.7" class="setting-slider" />
                <span id="vol-val" class="setting-val">70%</span>
              </div>
            </div>
            <div class="setting-row">
              <span class="setting-lbl">SWING</span>
              <div class="setting-controls">
                <input type="range" id="global-swing" min="0" max="1" step="0.01" value="0" class="setting-slider" />
                <span id="swing-val" class="setting-val">0%</span>
              </div>
            </div>
          </div>
        </div>

        <div class="r-panel" id="levels-panel">
          <div class="panel-titlebar">
            <span class="panel-title">LEVELS</span>
          </div>
          <div class="vu-meter-container">
            <div class="vu-channel">
              <div class="vu-bar">
                <div id="vu-l" class="vu-fill"></div>
              </div>
              <span class="vu-lbl">L</span>
            </div>
            <div class="vu-channel">
              <div class="vu-bar">
                <div id="vu-r" class="vu-fill"></div>
              </div>
              <span class="vu-lbl">R</span>
            </div>
            <div class="vu-scale">
              <span>0</span>
              <span>-6</span>
              <span>-12</span>
              <span>-24</span>
              <span>-48</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="rec-modal" class="modal-overlay" hidden>
    <div class="modal-box">
      <h3 class="modal-title">
        <svg fill="currentColor" width="14" height="14" viewBox="0 0 24 24"
          ><circle cx="12" cy="12" r="8"></circle>
        </svg>
        SELECT RECORDING MODE
      </h3>
      <p class="modal-desc">How would you like to record your performance?</p>
      <div class="modal-actions">
        <button id="btn-rec-manual" class="modal-btn">
          <span class="mb-title">MANUAL</span>
          <span class="mb-desc">Start and stop freely</span>
        </button>
        <button id="btn-rec-auto" class="modal-btn mb-auto">
          <span class="mb-title">AUTO (1 LOOP)</span>
          <span class="mb-desc">Exactly 1 cycle perfectly trimmed</span>
        </button>
      </div>
      <button id="btn-rec-cancel" class="modal-cancel">CANCEL</button>
    </div>
  </div>
</div>

<div id="toast-container" class="toast-container"></div>

<style>
  :root {
    --c-bg: #000000;
    --c-base: #0a0a0a;
    --c-panel: #121212;
    --c-panel2: #1a1a1a;
    --c-border: #262626;
    --c-border2: #333333;
    --c-accent: #ffffff;
    --c-green: #e5e5e5;
    --c-red: #737373;
    --c-text: #f5f5f5;
    --c-muted: #a3a3a3;
    --c-label: #737373;
    --f-mono: "Space Mono", "JetBrains Mono", "Fira Code", monospace;
    --f-ui: "DM Sans", "Inter", system-ui, sans-serif;
    --tb-h: 46px;
    --panel-title-h: 26px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 229, 255, 0.3) rgba(0, 0, 0, 0.2);
  }

  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(0, 229, 255, 0.3);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 229, 255, 0.6);
  }
  button {
    border: none;
    cursor: pointer;
    background: none;
    font-family: var(--f-ui);
  }

  #daw-root {
    display: flex;
    flex-direction: column;
    width: 100vw;
    height: 100vh;
    background: var(--c-bg);
    color: var(--c-text);
    font-family: var(--f-ui);
    font-size: 13px;
    overflow: hidden;
    user-select: none;
  }

  #daw-toolbar {
    height: var(--tb-h);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--c-base);
    border-bottom: 1px solid var(--c-border);
    padding: 0 12px;
  }

  .tb-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-right: 12px;
    border-right: 1px solid var(--c-border);
    flex-shrink: 0;
  }
  .tb-logo-icon {
    width: 22px;
    height: 22px;
  }
  .tb-brand-name {
    font-family: var(--f-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #fff;
  }
  .tb-brand-sub {
    color: var(--c-accent);
    margin-left: 2px;
    font-weight: 400;
    opacity: 0.8;
  }

  .tb-transport {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
  }

  .tb-sep {
    width: 1px;
    height: 24px;
    background: var(--c-border);
    margin: 0 4px;
    flex-shrink: 0;
  }

  .tb-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 28px;
    padding: 0 12px;
    border-radius: 4px;
    font-family: var(--f-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--c-text);
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    transition: all 0.15s;
  }
  .tb-btn svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
  .tb-btn:hover:not(:disabled) {
    border-color: var(--c-border2);
    background: var(--c-panel2);
  }
  .tb-btn:disabled {
    opacity: 0.35;
    pointer-events: none;
    filter: grayscale(1);
    cursor: not-allowed;
  }

  .tb-btn--play {
    color: var(--c-green);
    border-color: rgba(0, 255, 136, 0.25);
  }
  .tb-btn--play:hover:not(:disabled) {
    background: rgba(0, 255, 136, 0.08);
    border-color: var(--c-green);
  }
  .tb-btn--play.is-playing {
    background: rgba(0, 255, 136, 0.12);
    border-color: var(--c-green);
    box-shadow: 0 0 10px rgba(0, 255, 136, 0.2);
  }

  .tb-btn--init {
    color: #ffd700;
    border-color: rgba(255, 215, 0, 0.3);
  }
  .tb-btn--init:hover:not(:disabled) {
    background: rgba(255, 215, 0, 0.1);
    border-color: #ffd700;
    box-shadow: 0 0 8px rgba(255, 215, 0, 0.2);
  }


  .tb-btn--stop {
    color: #ff6078;
    border-color: rgba(255, 96, 120, 0.3);
  }
  .tb-btn--stop:hover:not(:disabled) {
    background: rgba(255, 96, 120, 0.12);
    border-color: #ff6078;
    box-shadow: 0 0 8px rgba(255, 96, 120, 0.2);
  }
  .tb-btn--stop:not(:disabled) {
    color: #ffb3bf;
    border-color: rgba(255, 96, 120, 0.5);
  }

  .tb-action-group {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .tb-btn--action {
    color: var(--c-muted);
    border-color: var(--c-border);
  }
  .tb-btn--action:hover {
    color: var(--c-text);
    border-color: var(--c-border2);
    background: var(--c-panel2);
  }

  .tb-bpm-group {
    display: flex;
    align-items: center;
    gap: 3px;
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 0 8px;
    height: 28px;
  }
  .tb-label {
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--c-label);
    margin-right: 4px;
  }
  .tb-bpm-val {
    font-family: var(--f-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--c-accent);
    min-width: 36px;
    width: 40px;
    text-align: center;
    font-variant-numeric: tabular-nums;
    background: none;
    border: none;
    outline: none;
    padding: 0;
    cursor: text;
    -moz-appearance: textfield;
  }
  .tb-bpm-val::-webkit-inner-spin-button,
  .tb-bpm-val::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .tb-bpm-val:focus {
    outline: 1px solid var(--c-accent);
    border-radius: 2px;
  }

  .tb-nudge {
    font-size: 12px;
    color: var(--c-muted);
    padding: 0 2px;
    border-radius: 2px;
    transition: color 0.1s;
    line-height: 1;
  }
  .tb-nudge:hover {
    color: var(--c-accent);
  }

  .tb-select {
    appearance: none;
    -webkit-appearance: none;
    background-color: var(--c-panel);
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23d881cc' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 4px center;
    background-size: 14px;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    color: var(--c-accent);
    font-family: var(--f-mono);
    font-size: 11px;
    padding: 2px 22px 2px 6px;
    cursor: pointer;
    outline: none;
    transition: all 0.2s;
  }
  .tb-select:hover {
    border-color: rgba(216, 129, 204, 0.5); 
  }
  .tb-select:focus {
    border-color: var(--c-accent);
    box-shadow: 0 0 0 1px rgba(216, 129, 204, 0.3);
  }

  .tb-time-group {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 0 10px;
    height: 28px;
  }
  .tb-time-val {
    font-family: var(--f-mono);
    font-size: 13px;
    color: var(--c-text);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.5px;
  }
  .tb-time-sep {
    color: var(--c-border2);
    font-size: 11px;
    margin: 0 4px;
  }

  .tb-rightmost {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .tb-info-btn {
    display: flex;
    align-items: center;
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    color: var(--c-accent);
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 0 10px;
    height: 28px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .tb-info-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: var(--c-text);
  }
  .tb-settings-wrap {
    position: relative;
  }
  .settings-popup {
    display: none;
    position: absolute;
    top: 100%;
    margin-top: 6px;
    right: 0;
    background: var(--c-panel2);
    border: 1px solid var(--c-border2);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.6);
    padding: 12px 14px;
    min-width: 200px;
    z-index: 9000;
    flex-direction: column;
    gap: 10px;
  }
  .tb-settings-wrap:hover .settings-popup {
    display: flex;
  }
  /* Invisible bridge to prevent closing when moving mouse to popup */
  .settings-popup::before {
    content: "";
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
  }
  .settings-popup-title {
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--c-label);
    margin-bottom: 2px;
  }
  .settings-popup-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .settings-popup-lbl {
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--c-muted);
    flex-shrink: 0;
  }

  .tb-status {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 0 10px;
    height: 28px;
    flex-shrink: 0;
  }
  .st-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: background 0.3s, box-shadow 0.3s;
  }
  .st-dot--idle {
    background: var(--c-muted);
  }
  .st-dot--ready {
    background: var(--c-green);
    box-shadow: 0 0 6px var(--c-green);
  }
  .st-dot--playing {
    background: var(--c-green);
    box-shadow: 0 0 6px var(--c-green);
    animation: blink 1.2s infinite;
  }
  .st-dot--error {
    background: var(--c-red);
    box-shadow: 0 0 6px var(--c-red);
  }
  .st-text {
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--c-muted);
    text-transform: uppercase;
  }

  #daw-main {
    flex: 1;
    display: flex;
    min-height: 0;
    overflow: hidden;
  }

  .panel-titlebar {
    height: var(--panel-title-h);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 10px;
    background: var(--c-base);
    border-bottom: 1px solid var(--c-border);
  }
  .panel-title {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--c-label);
    text-transform: uppercase;
  }
  .panel-actions {
    display: flex;
    gap: 6px;
  }
  .panel-action-btn {
    background: rgba(158, 207, 255, 0.1);
    border: 1px solid rgba(158, 207, 255, 0.3);
    border-radius: 4px;
    color: #9ecfff;

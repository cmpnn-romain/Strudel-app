<script>
  // @ts-nocheck
  import { webaudioRepl } from "@strudel/webaudio";
  import {
    getAudioContext,
    analysers,
    samples,
    registerSynthSounds,
  } from "superdough";
  import { registerSoundfonts } from "@strudel/soundfonts";
  import { evalScope } from "@strudel/core";
  import "@strudel/mini";
  import "@strudel/tonal";
  import "@strudel/soundfonts";

  const btnPlay = document.getElementById("btn-play");
  const btnPlayLbl = document.getElementById("btn-play-label");
  const btnInit = document.getElementById("btn-init");
  const btnStop = document.getElementById("btn-stop");
  const bpmUp = document.getElementById("bpm-up");
  const bpmDown = document.getElementById("bpm-down");
  const bpmDisplay = document.getElementById("bpm-display");
  const loopMode = document.getElementById("loop-mode");
  const timeEl = document.getElementById("tb-time");
  const codeEl = document.getElementById("sp-code");
  const lnEl = document.getElementById("line-numbers");
  const btnClear = document.getElementById("btn-clear");
  const btnUndo = document.getElementById("btn-undo");
  const btnRedo = document.getElementById("btn-redo");
  const fileImport = document.getElementById("file-import");
  const btnImportCode = document.getElementById("btn-import-code");
  const btnDlCode = document.getElementById("btn-dl-code");
  const btnRecVideo = document.getElementById("btn-rec-video");

  const recModal = document.getElementById("rec-modal");
  const btnRecManual = document.getElementById("btn-rec-manual");
  const btnRecAuto = document.getElementById("btn-rec-auto");
  const btnRecCancel = document.getElementById("btn-rec-cancel");

  const statusDot = document.getElementById("status-dot");
  const statusText = document.getElementById("status-text");
  const errorEl = document.getElementById("sp-error");
  const scopeCvs = document.getElementById("sp-visualizer");
  const specCvs = document.getElementById("sp-spectrum");
  const infoSampleRate = document.getElementById("info-samplerate");
  const vuL = document.getElementById("vu-l");
  const vuR = document.getElementById("vu-r");
  const scopeDb = document.getElementById("scope-db");

  let repl = null;
  let ready = false;
  let animId = null;
  let startTime = null;
  let cycleCount = 0;
  let bpm = 120;
  let isPlaying = false;
  let onceTimer = null;
  let isAutoRecording = false;

  const scopeCtx = scopeCvs.getContext("2d");
  const specCtx = specCvs.getContext("2d");

  const toastContainer = document.getElementById("toast-container");
  let toastTimer = null;

  function showToast(message) {
    const toast = document.createElement("div");
    toast.className = "toast";
    toast.innerHTML = `
      <span class="toast-icon">✕</span>
      <div class="toast-body">
        <div class="toast-title">Error</div>
        <div class="toast-msg">${message.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</div>
      </div>
      <button class="toast-close" title="Dismiss">✕</button>
    `;

    const closeBtn = toast.querySelector(".toast-close");
    function dismissToast() {
      toast.classList.add("toast--exit");
      toast.addEventListener("animationend", () => toast.remove(), { once: true });
    }
    closeBtn.addEventListener("click", dismissToast);

    toastContainer.appendChild(toast);

    // Auto-dismiss after 6 seconds
    setTimeout(dismissToast, 6000);
  }

  function setStatus(state, msg) {
    statusDot.className = `st-dot st-dot--${state}`;
    statusText.textContent = msg;
  }
  function showError(msg) {
    const text = String(msg?.message ?? msg);
    errorEl.textContent = text;
    errorEl.hidden = false;
    setStatus("error", "ERROR");
    showToast(text);
  }
  function clearError() {
    errorEl.hidden = true;
    errorEl.textContent = "";
  }

  const STORAGE_KEY = "strudel_saved_code";
  const DEFAULT_CODE = 's("bd sd hh sd").slow(2)';

  const savedCode = localStorage.getItem(STORAGE_KEY);
  if (savedCode !== null) {
    codeEl.value = savedCode;
  } else {
    codeEl.value = DEFAULT_CODE;
  }

  function syncLineNumbers() {
    const n = codeEl.value.split("\n").length;
    lnEl.textContent = Array.from({ length: n }, (_, i) => i + 1).join("\n");
  }

  // ── Undo / Redo history ──
  const history = [codeEl.value];
  let historyIndex = 0;
  let historyTimer = null;

  function updateHistoryButtons() {
    btnUndo.disabled = historyIndex <= 0;
    btnRedo.disabled = historyIndex >= history.length - 1;
  }

  function pushHistory(value) {
    // Trim any redo branch
    history.splice(historyIndex + 1);
    history.push(value);
    historyIndex = history.length - 1;
    updateHistoryButtons();
  }

  function applyHistory(index) {
    historyIndex = Math.max(0, Math.min(history.length - 1, index));
    codeEl.value = history[historyIndex];
    syncLineNumbers();
    localStorage.setItem(STORAGE_KEY, codeEl.value);
    updateHistoryButtons();
  }

  codeEl.addEventListener("input", () => {
    syncLineNumbers();
    localStorage.setItem(STORAGE_KEY, codeEl.value);
    // Debounce: snapshot after 600ms of idle typing
    clearTimeout(historyTimer);
    historyTimer = setTimeout(() => pushHistory(codeEl.value), 600);
  });
  codeEl.addEventListener("scroll", () => {
    lnEl.scrollTop = codeEl.scrollTop;
  });
  syncLineNumbers();
  updateHistoryButtons();

  btnUndo.addEventListener("click", () => applyHistory(historyIndex - 1));
  btnRedo.addEventListener("click", () => applyHistory(historyIndex + 1));

  // ── Beat Metronome ──
  const beatDots = [0,1,2,3].map(i => document.getElementById(`beat-${i}`));
  // Make beat-0 slightly bigger (downbeat accent)
  beatDots[0].classList.add("beat-accent");
  let beatIndex = -1;
  let beatInterval = null;

  function startMetronome() {
    stopMetronome();
    const intervalMs = (60 / bpm) * 1000;
    beatIndex = -1;
    beatInterval = setInterval(() => {
      if (beatIndex >= 0) beatDots[beatIndex].classList.remove("beat-on");
      beatIndex = (beatIndex + 1) % 4;
      beatDots[beatIndex].classList.add("beat-on");
    }, intervalMs);
  }
  function stopMetronome() {
    if (beatInterval) { clearInterval(beatInterval); beatInterval = null; }
    beatDots.forEach(d => d.classList.remove("beat-on"));
    beatIndex = -1;
  }

  // ── Tap Tempo ──
  const btnTap = document.getElementById("btn-tap");
  let tapTimes = [];
  let tapResetTimer = null;

  btnTap.addEventListener("click", () => {
    const now = performance.now();
    tapTimes.push(now);
    // Keep only the last 4 taps
    if (tapTimes.length > 4) tapTimes.shift();
    btnTap.classList.add("tap-active");
    clearTimeout(tapResetTimer);
    tapResetTimer = setTimeout(() => { tapTimes = []; btnTap.classList.remove("tap-active"); }, 2000);

    if (tapTimes.length >= 2) {
      let totalInterval = 0;
      for (let i = 1; i < tapTimes.length; i++) totalInterval += tapTimes[i] - tapTimes[i-1];
      const avgInterval = totalInterval / (tapTimes.length - 1);
      applyBpm(Math.round(60000 / avgInterval));
      if (isPlaying) startMetronome();
    }
  });

  // ── Editor: Font Size (Toolbar Only) ──
  const spFontDown = document.getElementById("sp-font-down");
  const spFontUp = document.getElementById("sp-font-up");
  const spFontVal = document.getElementById("sp-font-val");
  
  let fontSize = 13;
  const MIN_FONT = 10, MAX_FONT = 22;

  function applyFontSize(size) {
    fontSize = Math.max(MIN_FONT, Math.min(MAX_FONT, size));
    if (spFontVal) spFontVal.textContent = fontSize;
    
    codeEl.style.fontSize = `${fontSize}px`;
    codeEl.style.lineHeight = "1.75";
    lnEl.style.fontSize = `${fontSize}px`;
    
    const isMin = fontSize <= MIN_FONT;
    const isMax = fontSize >= MAX_FONT;
    if (spFontDown) spFontDown.disabled = isMin;
    if (spFontUp) spFontUp.disabled = isMax;
  }
  
  if (spFontDown) spFontDown.addEventListener("click", () => applyFontSize(fontSize - 1));
  if (spFontUp) spFontUp.addEventListener("click", () => applyFontSize(fontSize + 1));

  // ── Music: Volume & Swing ──
  const volSlider = document.getElementById("master-vol");
  const volVal = document.getElementById("vol-val");
  const swingSlider = document.getElementById("global-swing");
  const swingVal = document.getElementById("swing-val");

  globalThis.globalSwing = 0;

  function applyVolume(val) {
    const v = parseFloat(val);
    if (volVal) volVal.textContent = `${Math.round(v * 100)}%`;
    if (repl && repl.setMasterGain) {
      repl.setMasterGain(v);
    }
  }

  function applySwing(val) {
    const s = parseFloat(val);
    globalThis.globalSwing = s;
    if (swingVal) swingVal.textContent = `${Math.round(s * 100)}%`;
    // If the repl is active, we can also inject it into the eval scope
    if (repl && repl.eval) {
      // It's already in globalThis, so patterns can just use 'globalSwing'
    }
  }

  if (volSlider) volSlider.addEventListener("input", (e) => applyVolume(e.target.value));
  if (swingSlider) swingSlider.addEventListener("input", (e) => applySwing(e.target.value));

  // Initialize values
  applyVolume(0.7);
  applySwing(0);

  // ── Toolbar Settings Pop-up ──
  const btnSettings = document.getElementById("btn-settings");
  btnSettings.addEventListener("click", (e) => {
    e.preventDefault();
  });

  setInterval(() => {
    if (!startTime) {
      timeEl.textContent = "0:00.000";
      return;
    }
    const ms = performance.now() - startTime;
    const m = Math.floor(ms / 60000);
    const s = Math.floor((ms % 60000) / 1000);
    const ms3 = Math.floor(ms % 1000);
    timeEl.textContent = `${m}:${String(s).padStart(2, "0")}.${String(
      ms3
    ).padStart(3, "0")}`;
  }, 33);

  function fitCanvas(cvs) {
    const rect = cvs.parentElement.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    cvs.width = rect.width * dpr;
    cvs.height = (rect.height - 26) * dpr; // minus titlebar
    cvs.style.width = `${rect.width}px`;
    cvs.style.height = `${rect.height - 26}px`;
  }

  function drawIdleScope() {
    fitCanvas(scopeCvs);
    const W = scopeCvs.width,
      H = scopeCvs.height;
    scopeCtx.fillStyle = "#0d1117";
    scopeCtx.fillRect(0, 0, W, H);
    scopeCtx.strokeStyle = "rgba(30,42,58,0.7)";
    scopeCtx.lineWidth = 1;
    for (let y = 0; y <= 4; y++) {
      scopeCtx.beginPath();
      scopeCtx.moveTo(0, (H * y) / 4);
      scopeCtx.lineTo(W, (H * y) / 4);
      scopeCtx.stroke();
    }
    for (let x = 0; x <= 8; x++) {
      scopeCtx.beginPath();
      scopeCtx.moveTo((W * x) / 8, 0);
      scopeCtx.lineTo((W * x) / 8, H);
      scopeCtx.stroke();
    }
    scopeCtx.strokeStyle = "rgba(0,229,255,0.12)";
    scopeCtx.lineWidth = 1.5 * (window.devicePixelRatio || 1);
    scopeCtx.beginPath();
    scopeCtx.moveTo(0, H / 2);
    scopeCtx.lineTo(W, H / 2);
    scopeCtx.stroke();
  }

  function drawIdleSpec() {
    fitCanvas(specCvs);
    specCtx.fillStyle = "#0d1117";
    specCtx.fillRect(0, 0, specCvs.width, specCvs.height);
  }

  function drawViz() {
    animId = requestAnimationFrame(drawViz);

    const wA = analysers[1];
    if (!wA) return; // not yet connected (first beat hasn't fired)

    fitCanvas(scopeCvs);
    const SW = scopeCvs.width,
      SH = scopeCvs.height;
    const waveBuf = new Uint8Array(wA.frequencyBinCount);
    wA.getByteTimeDomainData(waveBuf);

    scopeCtx.fillStyle = "#0d1117";
    scopeCtx.fillRect(0, 0, SW, SH);

    const dpr = window.devicePixelRatio || 1;
    scopeCtx.strokeStyle = "rgba(30,42,58,0.5)";
    scopeCtx.lineWidth = 1 * dpr;
    for (let y = 0; y <= 4; y++) {
      scopeCtx.beginPath();
      scopeCtx.moveTo(0, (SH * y) / 4);
      scopeCtx.lineTo(SW, (SH * y) / 4);
      scopeCtx.stroke();
    }
    for (let x = 0; x <= 8; x++) {
      scopeCtx.beginPath();
      scopeCtx.moveTo((SW * x) / 8, 0);
      scopeCtx.lineTo((SW * x) / 8, SH);
      scopeCtx.stroke();
    }

    let peak = 0;
    for (let i = 0; i < waveBuf.length; i++) {
      peak = Math.max(peak, Math.abs(waveBuf[i] - 128));
    }
    const db = peak === 0 ? -Infinity : 20 * Math.log10(peak / 128);
    scopeDb.textContent = isFinite(db) ? `${db.toFixed(1)} dB` : "— dB";

    let pct = 0;
    if (isFinite(db) && db > -48) {
      pct = Math.min(100, Math.max(0, ((db + 48) / 48) * 100));
    }
    vuL.style.height = `${pct}%`;
    vuR.style.height = `${pct}%`;

    const grad = scopeCtx.createLinearGradient(0, 0, SW, 0);
    grad.addColorStop(0, "#0077ff");
    grad.addColorStop(0.5, "#00e5ff");
    grad.addColorStop(1, "#0077ff");
    scopeCtx.strokeStyle = grad;
    scopeCtx.lineWidth = 2 * dpr; // Scale thickness for Retina
    scopeCtx.lineJoin = "round";
    scopeCtx.lineCap = "round";
    scopeCtx.shadowColor = "#00e5ff";
    scopeCtx.shadowBlur = 6 * dpr; // Scale glow for Retina
    scopeCtx.beginPath();

    let triggerIndex = 0;
    const searchLimit = Math.floor(waveBuf.length / 2);
    for (let i = 0; i < searchLimit - 1; i++) {
      if (waveBuf[i] < 128 && waveBuf[i + 1] >= 128) {
        triggerIndex = i;
        break;
      }
    }

    const drawLen = searchLimit;
    const sliceW = SW / drawLen;
    let x = 0;

    for (let i = 0; i < drawLen; i++) {
      const idx = triggerIndex + i; // Offset by our zero-crossing anchor
      const val = idx < waveBuf.length ? waveBuf[idx] : 128;

      const y = ((val / 128) * SH) / 2;
      i === 0 ? scopeCtx.moveTo(x, y) : scopeCtx.lineTo(x, y);
      x += sliceW;
    }

    scopeCtx.stroke();
    scopeCtx.shadowBlur = 0;
    cycleCount++;

    fitCanvas(specCvs);
    const FW = specCvs.width,
      FH = specCvs.height;
    const freqBuf = new Uint8Array(wA.frequencyBinCount);
    wA.getByteFrequencyData(freqBuf);

    specCtx.fillStyle = "#0d1117";
    specCtx.fillRect(0, 0, FW, FH);

    const barCount = Math.min(128, Math.floor(FW / 4));
    const barW = FW / barCount - 1;
    for (let i = 0; i < barCount; i++) {
      const v = freqBuf[Math.floor((i * freqBuf.length) / barCount)] / 255;
      const bH = v * FH;
      const hue = 180 + v * 60;
      specCtx.fillStyle = `hsla(${hue},100%,60%,${0.4 + v * 0.6})`;
      specCtx.fillRect(i * (barW + 1), FH - bH, barW, bH);
    }
  }

  function stopViz() {
    if (animId) {
      cancelAnimationFrame(animId);
      animId = null;
    }
    drawIdleScope();
    drawIdleSpec();
  }

  function applyBpm(value) {
    bpm = Math.max(20, Math.min(300, Math.round(+value) || bpm));
    bpmDisplay.value = bpm;
    if (repl) repl.setCps(bpm / 60 / 4);
    if (isPlaying) startMetronome();
  }
  function updateBpm(delta) {
    applyBpm(bpm + delta);
  }
  bpmUp.addEventListener("click", () => updateBpm(+1));
  bpmDown.addEventListener("click", () => updateBpm(-1));
  bpmDisplay.addEventListener("change", () => applyBpm(bpmDisplay.value));
  bpmDisplay.addEventListener("blur", () => applyBpm(bpmDisplay.value));
  bpmDisplay.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      applyBpm(bpmDisplay.value);
      bpmDisplay.blur();
    }
  });

  async function ensureAudio() {
    if (ready) return true;
    setStatus("idle", "LOADING");
    try {
      await evalScope(
        import("@strudel/core"),
        import("@strudel/mini"),
        import("@strudel/tonal"),
        import("@strudel/soundfonts")
      );
      globalThis.miniAllStrings(); // ← registers the mini-notation string parser

      samples("github:tidalcycles/Dirt-Samples/master").catch(console.warn);

      registerSynthSounds();
      registerSoundfonts();

      repl = webaudioRepl({
        onError: (err) => {
          showError(err);
          isPlaying = false;
          btnPlay.classList.remove("is-playing");
          setStatus("error", "ERROR");
          startTime = null;
        }
      });
      applyVolume(volSlider.value);
      const ctx = getAudioContext() ?? new AudioContext();
      if (ctx.state === "suspended") await ctx.resume();

      ready = true;
      infoSampleRate.textContent = `${ctx.sampleRate} Hz`;
      return true;
    } catch (err) {
      console.error("[DAW] audio init error:", err);
      showError(err);
      return false;
    }
  }

  btnInit.addEventListener("click", async () => {
    btnInit.disabled = true;
    const ok = await ensureAudio();
    if (ok) {
      btnInit.style.display = "none"; // Hide after successful init
      btnPlay.disabled = false; // Enable PLAY
    } else {
      btnInit.disabled = false;
    }
  });

  async function play() {
    clearError();
    const code = codeEl.value.trim();
    if (!code) return;

    const ok = await ensureAudio();
    if (!ok || !repl) return;

    btnInit.style.display = "none";
    btnPlay.disabled = true; // grey out PLAY
    btnStop.disabled = false; // enable STOP

    isPlaying = true;
    btnPlay.classList.add("is-playing");
    setStatus("playing", "PLAYING");
    startTime = performance.now();

    if (!animId) drawViz();

    try {
      // Strip trailing semicolons so .analyze(1) can be appended safely
      const cleanCode = code.replace(/[;\s]+$/, '');
      await repl.evaluate(`(\n${cleanCode}\n).analyze(1)`);

      setStatus("playing", "PLAYING");

      const isOnce = loopMode.value === "once";
      if (isOnce) {
        const cycleMs = (240 / bpm) * 1000;
        onceTimer = setTimeout(() => {
          if (isPlaying) btnStop.click();
        }, cycleMs);
      }
    } catch (err) {
      console.error("[DAW] evaluate error:", err);
      showError(err);
      isPlaying = false;
      btnPlay.classList.remove("is-playing");
      setStatus("error", "ERROR");
      startTime = null;
    }
  }

  btnPlay.addEventListener("click", play);
  btnClear.addEventListener("click", () => {
    codeEl.value = "";
    syncLineNumbers();
    localStorage.removeItem(STORAGE_KEY);
    codeEl.focus();
  });

  btnImportCode.addEventListener("click", () => {
    fileImport.click();
  });

  fileImport.addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (ev) => {
      const content = ev.target.result;
      codeEl.value = content;
      syncLineNumbers();
      localStorage.setItem(STORAGE_KEY, content);
    };
    reader.readAsText(file);
    e.target.value = "";
  });

  btnDlCode.addEventListener("click", () => {
    const code = codeEl.value;
    const blob = new Blob([code], { type: "text/plain" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `strudel-pattern-${Date.now()}.strudel`;
    a.click();
    URL.revokeObjectURL(url);
  });

  let mediaRecorder = null;
  let recordedChunks = [];

  btnRecVideo.addEventListener("click", () => {
    if (mediaRecorder && mediaRecorder.state === "recording") {
      mediaRecorder.stop();
      btnRecVideo.textContent = "● REC";
      btnRecVideo.style.color = "";
      btnRecVideo.style.borderColor = "";
      isAutoRecording = false;
      return;
    }

    if (!ready || !getAudioContext()) {
      showError(
        "Please click INIT (or PLAY) first to initialize audio before recording."
      );
      return;
    }

    recModal.hidden = false;
  });

  btnRecCancel.addEventListener("click", () => {
    recModal.hidden = true;
  });

  async function startRecording(type) {
    recModal.hidden = true; // hide modal

    try {
      const audioCtx = getAudioContext();
      const dest = audioCtx.createMediaStreamDestination();
      const wA = analysers[1]; // We can connect our analyser to the media dest
      if (wA) {
        wA.connect(dest);
      }
      
      const canvasStream = scopeCvs.captureStream(60);
      const audioStream = dest.stream;
      
      const tracks = [
        ...canvasStream.getVideoTracks(),
        ...audioStream.getAudioTracks()
      ];
      const stream = new MediaStream(tracks);

      mediaRecorder = new MediaRecorder(stream, { mimeType: "video/webm" });
      recordedChunks = [];

      mediaRecorder.ondataavailable = (e) => {
        if (e.data.size > 0) recordedChunks.push(e.data);
      };

      mediaRecorder.onstop = () => {
        const blob = new Blob(recordedChunks, { type: "video/webm" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `strudel-performance-${Date.now()}.webm`;
        a.click();
        URL.revokeObjectURL(url);

        stream.getTracks().forEach((track) => track.stop());
        // Disconnect analyser from recording destination to prevent audio graph leakage
        try { if (wA) wA.disconnect(dest); } catch {}
      };

      mediaRecorder.start();
      btnRecVideo.textContent = "■ STOP REC";
      btnRecVideo.style.color = "#ef4444";
      btnRecVideo.style.borderColor = "#ef4444";

      if (type === "auto") {
        isAutoRecording = true;
        loopMode.value = "once";
        play();
      } else {
        isAutoRecording = false;
      }
    } catch (err) {
      console.error("Recording failed:", err);
      showError(
        "Video export failed. Browser may not support MediaRecorder for WebM."
      );
    }
  }

  btnRecManual.addEventListener("click", () => startRecording("manual"));
  btnRecAuto.addEventListener("click", () => startRecording("auto"));

  codeEl.addEventListener("keydown", (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
      e.preventDefault();
      play();
    }
  });

  btnStop.addEventListener("click", () => {
    if (onceTimer) {
      clearTimeout(onceTimer);
      onceTimer = null;
    }

    if (repl) {
      try {
        repl.stop();
      } catch {}
    }
    clearError();
    isPlaying = false;
    btnPlay.classList.remove("is-playing");
    btnPlay.disabled = false; // re-enable PLAY
    btnStop.disabled = true; // grey out STOP
    startTime = null;
    cycleCount = 0;
    stopViz();
    setStatus(ready ? "ready" : "idle", ready ? "READY" : "OFFLINE");

    if (mediaRecorder && mediaRecorder.state === "recording") {
      btnRecVideo.click(); // trigger stop
    }
  });

  requestAnimationFrame(() => {
    drawIdleScope();
    drawIdleSpec();
  });
</script>

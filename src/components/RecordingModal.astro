---
/**
 * RecordingModal Component
 * Modal for selecting recording mode.
 */
---
<div id="rec-modal" class="modal-overlay" hidden>
  <div class="modal-box">
    <h3 class="modal-title">
      <svg fill="currentColor" width="14" height="14" viewBox="0 0 24 24"
        ><circle cx="12" cy="12" r="8"></circle>
      </svg>
      SELECT RECORDING MODE
    </h3>
    <p class="modal-desc">How would you like to record your performance?</p>
    <div class="modal-actions">
      <button id="btn-rec-manual" class="modal-btn">
        <span class="mb-title">MANUAL</span>
        <span class="mb-desc">Start and stop freely</span>
      </button>
      <button id="btn-rec-auto" class="modal-btn mb-auto">
        <span class="mb-title">AUTO (1 LOOP)</span>
        <span class="mb-desc">Exactly 1 cycle perfectly trimmed</span>
      </button>
    </div>
    <button id="btn-rec-cancel" class="modal-cancel">CANCEL</button>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
  }
  .modal-overlay[hidden] {
    display: none !important;
  }
  .modal-box {
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: 30px;
    width: 440px;
    max-width: 90vw;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    text-align: center;
  }
  .modal-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--c-text);
  }
  .modal-desc {
    color: var(--c-muted);
    font-size: 13px;
    margin-bottom: 30px;
    line-height: 1.5;
  }
  .modal-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
  }
  .modal-btn {
    flex: 1;
    background: var(--c-panel2);
    border: 1px solid var(--c-border);
    padding: 20px 15px;
    border-radius: 6px;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
    color: var(--c-text);
  }
  .mb-title {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
  }
  .mb-desc {
    font-size: 10px;
    color: var(--c-muted);
  }
  .modal-btn:hover {
    border-color: var(--c-accent);
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(-2px);
  }
  .mb-auto:hover {
    border-color: #00e5ff;
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.2);
  }
  .modal-cancel {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--c-muted);
    text-decoration: underline;
    opacity: 0.6;
    transition: opacity 0.2s;
    background: none;
    border: none;
    cursor: pointer;
  }
  .modal-cancel:hover {
    opacity: 1;
  }
</style>

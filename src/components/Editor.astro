---
---
<aside id="panel-code">
  <div class="panel-titlebar">
    <span class="panel-title">
      <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"
        ><path
          d="M5.5 2l-4 6 4 6M10.5 2l4 6-4 6"
          stroke="currentColor"
          stroke-width="1.5"
          fill="none"></path>
      </svg>
      PATTERN EDITOR
    </span>
    <div class="panel-actions">
      <button
        id="btn-undo"
        class="panel-action-btn panel-icon-btn"
        title="Undo (Ctrl+Z)">↺</button>
      <button
        id="btn-redo"
        class="panel-action-btn panel-icon-btn"
        title="Redo (Ctrl+Shift+Z)">↻</button>
      <div class="panel-actions-sep"></div>
      <button
        id="btn-clear"
        class="panel-action-btn btn-danger"
        title="Clear Code">CLEAR</button
      >
    </div>
  </div>

  <div class="editor-area">
    <div id="line-numbers" class="line-numbers" aria-hidden="true">1</div>
    <textarea
      id="sp-code"
      class="sp-code"
      spellcheck="false"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      aria-label="Strudel pattern code"></textarea>
  </div>

  <pre id="sp-error" class="error-console" hidden></pre>
</aside>

<style>
  #panel-code {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    background: var(--c-panel);
    border-right: 1px solid var(--c-border);
  }
  .panel-titlebar {
    height: var(--panel-title-h);
    background: var(--c-base);
    border-bottom: 1px solid var(--c-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 10px;
    flex-shrink: 0;
  }
  .panel-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--c-muted);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .panel-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .panel-action-btn {
    font-size: 10px;
    font-weight: 700;
    color: var(--c-muted);
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid var(--c-border2);
    background: var(--c-panel2);
    transition: all 0.2s;
    cursor: pointer;
  }
  .panel-action-btn:hover:not(:disabled) {
    color: var(--c-text);
    border-color: var(--c-text);
  }
  .panel-icon-btn {
    font-size: 14px;
    padding: 0 6px;
  }
  .panel-action-btn:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .panel-actions-sep {
    width: 1px;
    height: 12px;
    background: var(--c-border);
    margin: 0 2px;
  }
  .btn-danger {
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
  }
  .btn-danger:hover:not(:disabled) {
    background: rgba(239, 68, 68, 0.1);
    color: #fca5a5;
    border-color: #ef4444;
  }

  .editor-area {
    flex: 1;
    display: flex;
    overflow: hidden;
    position: relative;
    background: #0a0a0a;
  }
  .line-numbers {
    width: 40px;
    padding: 15px 5px;
    text-align: right;
    font-family: var(--f-mono);
    font-size: 13px;
    color: #3a3a3a;
    background: #050505;
    user-select: none;
    line-height: 1.75;
    border-right: 1px solid #111;
    overflow: hidden;
    white-space: pre;
  }
  .sp-code {
    flex: 1;
    height: 100%;
    background: transparent;
    color: #e5e5e5;
    border: none;
    outline: none;
    font-family: var(--f-mono);
    font-size: 13px;
    line-height: 1.75;
    padding: 15px;
    resize: none;
    white-space: pre;
    overflow-wrap: normal;
    tab-size: 2;
  }
  .error-console {
    max-height: 150px;
    background: #1a0505;
    color: #fca5a5;
    font-family: var(--f-mono);
    font-size: 12px;
    padding: 12px 15px;
    border-top: 1px solid #3b0a0a;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>

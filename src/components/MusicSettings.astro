---
/**
 * MusicSettings Component
 * Contains Volume and Swing sliders.
 */
---
<div class="r-panel" id="settings-panel">
  <div class="panel-titlebar">
    <span class="panel-title">MUSIC SETTINGS</span>
  </div>
  <div class="merged-settings-content">
    <div class="v-slider-group">
      <div class="v-slider-wrap">
        <input type="range" id="master-vol" min="0" max="1" step="0.01" value="0.7" class="v-slider" />
      </div>
      <span class="v-slider-lbl">VOL</span>
      <span id="vol-val" class="v-slider-val">70%</span>
    </div>

    <div class="v-slider-group">
      <div class="v-slider-wrap">
        <input type="range" id="master-pan" min="-1" max="1" step="0.01" value="0" class="v-slider" />
      </div>
      <span class="v-slider-lbl">PAN</span>
      <span id="pan-val" class="v-slider-val">C</span>
    </div>

    <div class="v-slider-sep"></div>

    <div class="v-slider-group">
      <div class="v-slider-wrap">
        <input type="range" id="low-cut" min="20" max="1000" step="1" value="20" class="v-slider" />
      </div>
      <span class="v-slider-lbl">LO CUT</span>
      <span id="low-cut-val" class="v-slider-val">20Hz</span>
    </div>

    <div class="v-slider-group">
      <div class="v-slider-wrap">
        <input type="range" id="high-cut" min="1000" max="20000" step="1" value="20000" class="v-slider" />
      </div>
      <span class="v-slider-lbl">HI CUT</span>
      <span id="high-cut-val" class="v-slider-val">20k</span>
    </div>

    <div class="v-slider-sep"></div>

    <div class="v-slider-group">
      <div class="v-slider-wrap">
        <input type="range" id="global-swing" min="0" max="1" step="0.01" value="0" class="v-slider" />
      </div>
      <span class="v-slider-lbl">SWING</span>
      <span id="swing-val" class="v-slider-val">0%</span>
    </div>
  </div>
</div>

<style>
  #settings-panel {
    flex: 1;
  }
  .r-panel {
    background: var(--c-panel);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .panel-titlebar {
    height: var(--panel-title-h);
    background: var(--c-base);
    border-bottom: 1px solid var(--c-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 10px;
    flex-shrink: 0;
  }
  .panel-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--c-muted);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .merged-settings-content {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    padding: 15px 10px;
    gap: 4px;
  }
  .v-slider-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 40px;
  }
  .v-slider-wrap {
    height: 70px;
    width: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .v-slider {
    -webkit-appearance: none;
    width: 70px; /* Width is height because of rotation */
    height: 4px;
    background: var(--c-border2);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    transform: rotate(-90deg);
    position: absolute;
  }
  .v-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--c-text);
    cursor: pointer;
    border: 2px solid var(--c-panel);
    box-shadow: 0 0 5px rgba(0,0,0,0.5);
  }
  .v-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--c-text);
    cursor: pointer;
    border: 2px solid var(--c-panel);
  }
  .v-slider-lbl {
    font-size: 8px;
    font-weight: 700;
    color: var(--c-label);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    text-align: center;
    white-space: nowrap;
  }
  .v-slider-val {
    font-family: var(--f-mono);
    font-size: 9px;
    color: var(--c-muted);
    min-width: 24px;
    text-align: center;
  }
  .v-slider-sep {
    width: 1px;
    height: 80%;
    background: var(--c-border);
    margin: 0 4px;
    align-self: center;
  }
</style>
